<Window x:Class="Wpf_odtsar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_odtsar"
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="800">
    <Grid Margin="10,7,10,-5" RenderTransformOrigin="0.5,0.5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="29*"/>
        </Grid.ColumnDefinitions>
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleY="1"/>
                <SkewTransform/>
                <RotateTransform/>
                <TranslateTransform/>
            </TransformGroup>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="378.04"/>
            <RowDefinition Height="0*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="Black" BorderThickness="1" Background="Black" CornerRadius="30,30,30,30" Grid.RowSpan="3" Margin="0,1,0,36" Grid.ColumnSpan="2">
            <TextBlock x:Name="TimerLable" TextWrapping="Wrap" Margin="246,294,381,-16" Background="#FFD42E2E" FontSize="30" RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="-27.578"/>
                        <RotateTransform/>
                        <TranslateTransform X="-4.45"/>
                    </TransformGroup>
                </TextBlock.RenderTransform><Run Language="sk-sk" Text="---.--- s"/></TextBlock>
        </Border>
        <Ellipse x:Name="_1" Stroke="Black" Margin="0,157,520,147" RenderTransformOrigin="0.5,0.5" Fill="#FF5D0000" Grid.RowSpan="3" HorizontalAlignment="Right" Width="57" Grid.Column="1">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.137"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.619"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="_0" Stroke="Black" Margin="6,259,134,70" RenderTransformOrigin="2.261,-1.154" Fill="#FF5D0000" Grid.RowSpan="3">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.137"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.872"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="_3" Stroke="Black" Margin="250,168,263,156" RenderTransformOrigin="0.5,0.5" Fill="#FF5D0000" Grid.RowSpan="3" Grid.Column="1">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.137"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.619"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="_4" Stroke="Black" Margin="388,176,151,157" RenderTransformOrigin="0.5,0.5" Fill="#FF5D0000" Grid.RowSpan="3" Grid.Column="1">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.137"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.619"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="_2" Stroke="Black" Margin="117,183,408,141" RenderTransformOrigin="0.5,0.5" Fill="#FF5D0000" Grid.RowSpan="3" Grid.Column="1">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.137"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.619"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Button x:Name="StartButton" Content="Start&#xD;&#xA;" Margin="30,77,418,252" Grid.RowSpan="3" Grid.ColumnSpan="2" Click="StartButton_Click"/>
        <Button x:Name="GoButton" Content="GO&#xD;&#xA;,&#xD;&#xA;" HorizontalAlignment="Left" Margin="306,62,0,0" VerticalAlignment="Top" RenderTransformOrigin="17.277,8.369" Grid.Column="1" Grid.RowSpan="3" Height="60" Width="96" Click="GoButton_Click"/>
        <Label x:Name="Time_Shower" Grid.Column="1" Content="Label" HorizontalAlignment="Left" Margin="147,76,0,0" Grid.Row="6" VerticalAlignment="Top" Width="233"/>
    </Grid>
</Window>
